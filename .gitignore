# --- Dépendances ---
node_modules/
.pnpm-store/

# --- Builds et Dist ---
# Ignore tous les dossiers dist dans toutes les apps
apps/*/dist/
apps/*/build/
# Si vous avez des dossiers packages partagés
packages/*/dist/

# --- Fichiers d'environnement (SÉCURITÉ CRITIQUE) ---
.env
.env.local
.env.development
.env.test
.env.production

**/.env
**/.env.local
**/.env.development
**/.env.test
**/.env.production
**/.env.*.local

# Spécifique à certains projets
.env.*.local

# --- Logs et Debug ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Éditeurs et IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Testing ---
coverage/
*.lcov
.nyc_output/

# --- Prisma ---
# On garde schema.prisma et migrations, mais on ignore le client généré
# car il est régénéré à chaque build/install
apps/*/src/generated/
apps/*/node_modules/.prisma/

# --- Docker (optionnel si vous ne voulez pas committer les configs locales) ---
# Gardez Dockerfile et docker-compose.yml, ignorez seulement :
.docker/

# --- Temp files ---
tmp/
temp/