generator client {
  provider = "prisma-client"
  output    = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GoalStatus {
  A_FAIRE
  EN_COURS
  TERMINE
}

model Week {
  id Int @default(autoincrement()) @id
  description String
  startDate   DateTime @unique
  endDate DateTime @unique
  summary String
  comments String
  goals Goal[]
}

model Goal {
  id Int @default(autoincrement()) @id
  title String
  status GoalStatus @default(A_FAIRE)
  description String?
  weekId Int
  week Week @relation(fields: [weekId],references: [id],onDelete: Cascade)
}
